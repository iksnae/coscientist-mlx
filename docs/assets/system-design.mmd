flowchart TB
    sci(["Scientist"]):::person --> goal["Research goal · run config"]:::io
    goal --> SYS

    subgraph SYS["AI co-scientist · multi-agent engine"]
        direction TB
        subgraph PASS1["Initial pass"]
            direction LR
            GEN["Generation"]:::gen --> REF["Reflection"]:::rev --> RANK["Ranking"]:::rank --> TOUR["Tournament<br/>Elo k=24"]:::tour
        end
        subgraph PASS2["Refinement loop x N"]
            direction LR
            META["Meta-Review"]:::meta --> EVO["Evolution"]:::evo --> RR["Reflection ·<br/>Ranking · Tournament"]:::rev --> PROX["Proximity<br/>clusters"]:::prox
            PROX -. "self-improving" .-> META
        end
        PASS1 --> PASS2
    end

    SYS --> RES
    SYS -. "routes each stage" .-> BACK

    subgraph RES["Results → returned to scientist"]
        direction LR
        OUT["Top-ranked + meta-review + clusters"]:::io --> SNAP["RunStore · JSON"]:::muted
    end

    subgraph BACK["Backends · DecoderRouting"]
        direction LR
        MLX["On-device MLX<br/>Metal · private"]:::mlx
        REM["Remote<br/>OpenAI-compatible"]:::rem
        DEC["Schema decode<br/>+ repair-retry"]:::muted
    end

