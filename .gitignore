# Swift / SwiftPM
.build/
.swiftpm/
*.xcodeproj
*.xcworkspace

# xcodebuild derived data (required for GPU/Metal builds — see README)
.xcbuild/
.xcbuild-ios/
.xcbuild-mac/

# Coverage / profiling artifacts from xcodebuild runs
*.profraw

# macOS
.DS_Store

# Xcode user state
xcuserdata/
*.xcuserstate

# Models / large local artifacts (downloaded at runtime, never committed)
Models/
*.safetensors
*.gguf


# DocC static site (generated by .github/workflows/docs.yml)
docs-site/

# Image-gen receipts (audit artifacts, not deliverables — the PNGs are committed)
docs/assets/*.receipt.json

# LOSWF
.loswf/